{
  "name": "physics-roadmap",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "oxlint --deny-warnings",
    "lint:fix": "oxlint --deny-warnings --fix",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "lint:text": "textlint \"**/*.{md,mdx}\"",
    "lint:text:fix": "textlint --fix \"**/*.{md,mdx}\"",
    "check": "pnpm run format:check && pnpm run lint && pnpm run lint:text",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.0",
    "@astrojs/starlight": "^0.40.0",
    "@mermaid-js/layout-elk": "^0.2.1",
    "astro": "^7.0.0",
    "astro-mermaid": "^2.0.4",
    "d3-scale": "^4.0.2",
    "katex": "^0.17.0",
    "mermaid": "^11.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@types/d3-scale": "^4.0.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "lefthook": "^2.1.9",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "0.23.0",
    "textlint": "^15.7.1",
    "textlint-filter-rule-comments": "^1.3.0",
    "textlint-plugin-mdx": "^1.1.0",
    "textlint-rule-preset-ja-spacing": "^3.0.2",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2"
  },
  "packageManager": "pnpm@11.8.0"
